{
  "name": "poh-duplicate-finder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "core",
    "indexer",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w core && npm run build -w web",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -p core/tsconfig.json --noEmit && tsc -p netlify/tsconfig.json --noEmit && tsc -p indexer/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "prepare": "husky",
    "indexer": "npm run build -w core && npm run start -w indexer --"
  },
  "dependencies": {
    "@pohdf/core": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
